{
  "version": "1.0",
  "name": "Glowing Line with Trim Path Wipe",
  "actions": [
    {
      "type": "create_shape",
      "name": "Glow_Line",
      "shape": "line",
      "from": [200, 500],
      "to": [800, 500],
      "strokeWidth": 4,
      "strokeColor": [0, 0.8, 1],
      "effects": ["glow"],
      "animate": {
        "property": "trimPath",
        "from": 0,
        "to": 100,
        "duration": 1.2,
        "easing": "easeOutCubic"
      }
    }
  ]
}
