{
  "version": "1.0",
  "name": "Mixed Text + Shape + Legacy Animation",
  "actions": [
    {
      "type": "create_text",
      "name": "Title",
      "text": "Welcome",
      "position": [960, 150],
      "style": {
        "fontSize": 72,
        "fillColor": [1, 1, 1],
        "justification": "center"
      },
      "animate": {
        "preset": "fade-in",
        "duration": 0.6
      }
    },
    {
      "type": "create_shape",
      "name": "Underline",
      "shape": "line",
      "from": [400, 220],
      "to": [1520, 220],
      "strokeWidth": 2,
      "strokeColor": [1, 0.8, 0],
      "animate": {
        "property": "trimPath",
        "from": 0,
        "to": 100,
        "duration": 0.8,
        "delay": 0.3,
        "easing": "easeOutCubic"
      }
    }
  ],
  "animations": [
    {
      "preset": "pop",
      "target": { "mode": "pattern", "pattern": "^Card" },
      "stagger": {
        "delay": 0.1,
        "order": "index"
      }
    }
  ]
}
