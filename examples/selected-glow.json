{
  "version": "1.0",
  "name": "Selected Layers Glow",
  "animations": [
    {
      "target": { "mode": "selected" },
      "properties": [
        { "property": "opacity", "from": 0, "to": 100 },
        { "property": "scale", "from": 80, "to": 100 }
      ],
      "easing": "easeOutExpo",
      "duration": 0.5,
      "effects": [
        {
          "type": "glow",
          "params": {
            "threshold": 60,
            "radius": 25,
            "intensity": 2
          }
        }
      ]
    }
  ]
}
