{
  "version": "1.0",
  "name": "Logo Accordion Spin + Brand Reveal",
  "actions": [
    {
      "target": { "mode": "all" },
      "properties": [
        { "property": "scale", "from": 135, "to": 100 },
        { "property": "position", "from": [0, 30], "to": [0, 0], "relative": true },
        { "property": "opacity", "from": 0, "to": 100 }
      ],
      "easing": "easeOutBack",
      "duration": 1.0,
      "stagger": { "delay": 0.15, "order": "center" }
    },
    {
      "target": { "mode": "all" },
      "properties": [
        { "property": "rotation", "from": 0, "to": 360 },
        { "property": "position", "from": [0, 0], "to": [-450, 0], "relative": true }
      ],
      "easing": "easeInOutQuad",
      "duration": 1.0,
      "startAt": 1.5
    },
    {
      "type": "create_text",
      "name": "Brand",
      "text": "shipped.one",
      "position": [1100, 540],
      "style": {
        "fontSize": 52,
        "fillColor": [1, 1, 1],
        "justification": "left"
      },
      "animate": {
        "property": "typewriter",
        "duration": 1.5,
        "easing": "linear",
        "startAt": 2.8
      }
    }
  ]
}
